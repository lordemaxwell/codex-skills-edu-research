# Optional override. If omitted, scripts/run.py tries common Python paths first.
LIT_HARVEST_PYTHON=D:\Python\Python311\python.exe

# Preferred browser channel for Playwright persistent sessions.
LIT_HARVEST_BROWSER_CHANNEL=msedge

# Keep CNKI visible by default because login and verification often require manual action.
LIT_HARVEST_CNKI_HEADLESS=0

# Optional Zotero Web API credentials.
ZOTERO_USER_ID=
ZOTERO_API_KEY=
